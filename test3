print("-------JQL cannot do regex, you must filter in Python-----")

issues = client.search_issues(
    'project = KAN AND description ~ "demo"',
    maxResults=100
)

filtered = [
    i for i in issues
    if i.fields.description and ".demo" in i.fields.description
]

for i in filtered:
    print(i.key, i.fields.summary)


